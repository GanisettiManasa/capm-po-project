{
  "xsappname": "cap-s4-onprem",
  "tenant-mode": "dedicated",
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/**"
    ]
  },
  "scopes": [
    {
      "name": "$XSAPPNAME.viewer",
      "description": "Viewer access"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "Viewer role",
      "scope-references": [
        "$XSAPPNAME.viewer"
      ]
    }
  ]
}
