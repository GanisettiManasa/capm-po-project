<mvc:View
    controllerName="poapp.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <App id="_IDGenApp">
        <Page id="_IDGenPage" title="PO Monitor">

            <VBox id="_IDGenVBox1" class="sapUiSmallMargin">

                <!-- 🔍 Filters -->
                <HBox id="_IDGenHBox">
                    <Input id="poInput" placeholder="Purchase Order"/>
                    <Input id="plantInput" placeholder="Plant"/>
                    <Input id="materialInput" placeholder="Material"/>
                    <Button id="_IDGenButton" text="Search" press="onSearch"/>
                </HBox>

                <!-- 📊 Table -->
                <Table id="poTable" items="{/PO}" growing="true">

                    <columns>
                        <Column id="_IDGenColumn"><Text id="_IDGenText" text="PO"/></Column>
                        <Column id="_IDGenColumn1"><Text id="_IDGenText1" text="Item"/></Column>
                        <Column id="_IDGenColumn2"><Text id="_IDGenText2" text="Material"/></Column>
                        <Column id="_IDGenColumn3"><Text id="_IDGenText3" text="Plant"/></Column>
                        <Column id="_IDGenColumn4"><Text id="_IDGenText4" text="Qty"/></Column>
                        <Column id="_IDGenColumn5"><Text id="_IDGenText5" text="Price"/></Column>
                    </columns>

                    <items>
                        <ColumnListItem id="_IDGenColumnListItem">
                            <cells>
                                <Text id="_IDGenText6" text="{PurchaseOrder}"/>
                                <Text id="_IDGenText7" text="{PurchaseOrderItem}"/>
                                <Text id="_IDGenText8" text="{Material}"/>
                                <Text id="_IDGenText9" text="{Plant}"/>
                                <Text id="_IDGenText10" text="{OrderQuantity}"/>
                                <Text id="_IDGenText11" text="{NetPriceAmount}"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>

        </Page>
    </App>

</mvc:View>
