<mvc:View
    controllerName="poapp.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <App id="app">

        <pages>

            <Page id="pagepo" title="PO Header">

                <VBox id="mainVBox" class="sapUiSmallMargin">

                    <!-- 🔍 Filters -->
                    <HBox id="filterBox">
                        <Input id="poInput" placeholder="PurchaseOrder"/>
                        <Input id="purchaseGrpInput" placeholder="PurchasingGroup"/>
                        <Input id="supplierInput" placeholder="Suppliersr"/>
                        <Button id="searchBtn" text="Search" press="onSearch"/>
                    </HBox>

                    <!-- 📊 Table -->
                    <Table id="poTable" items="{/POHeader}" growing="true">

                        <columns>
                            <Column id="colPO"><Text id="_IDGenText1" text="PO"/></Column>
                            <Column id="colType"><Text id="_IDGenText2" text="Type"/></Column>
                            <Column id="colSupplier"><Text id="_IDGenText3" text="Supplier"/></Column>
                            <Column id="colCreation"><Text id="_IDGenText4" text="CreationDate"/></Column>
                            <Column id="colPODate"><Text id="_IDGenText5" text="PODate"/></Column>
                            <Column id="colOrg"><Text id="_IDGenText6" text="PurchasingOrg"/></Column>
                            <Column id="colGrp"><Text id="_IDGenText7" text="PurchasingGrp"/></Column>
                            <Column id="colCur"><Text id="_IDGenText8" text="DocCur"/></Column>
                            <Column id="colPay"><Text id="_IDGenText9" text="PaymentTerms"/></Column>
                            <Column id="colStatus"><Text id="_IDGenText10" text="Status"/></Column>
                        </columns>

                        <items>
                            <ColumnListItem id="_IDGenColumnListItem">
                                <cells>
                                    <Text id="_IDGenText11" text="{PurchaseOrder}"/>
                                    <Text id="_IDGenText12" text="{PurchaseOrderType}"/>
                                    <Text id="_IDGenText13" text="{Supplier}"/>
                                    <Text id="_IDGenText14" text="{CreationDate}"/>
                                    <Text id="_IDGenText15" text="{PurchaseOrderDate}"/>
                                    <Text id="_IDGenText16" text="{PurchasingOrganization}"/>
                                    <Text id="_IDGenText17" text="{PurchasingGroup}"/>
                                    <Text id="_IDGenText18" text="{DocumentCurrency}"/>
                                    <Text id="_IDGenText19" text="{PaymentTerms}"/>
                                    <Text id="_IDGenText20" text="{PurchasingProcessingStatus}"/>
                                </cells>
                            </ColumnListItem>
                        </items>

                    </Table>

                </VBox>

            </Page>

        </pages>

    </App>

</mvc:View>
