{
  "welcomeFile": "/index.html",
  "routes": [
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "csrfProtection": false,
      "authenticationType": "none"
    },
    {
      "source": "^(.*)$",
      "localDir": "webapp",
      "authenticationType": "none"
    }
  ]
}
