<mvc:View
    controllerName="poapp.controller.Items"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page id="_IDGenPage" title="PO Items" showNavButton="true" navButtonPress="onNavBack">

        <Table id="itemsTable" items="{/POItem}">
            <columns>
                <Column id="_IDGenColumn1"><Text id="_IDGenText" text="PO"/></Column>
                <Column id="_IDGenColumn2"><Text id="_IDGenText21" text="Item"/></Column>
                <Column id="_IDGenColumn3"><Text id="_IDGenText22" text="Material"/></Column>
                <Column id="_IDGenColumn4"><Text id="_IDGenText23" text="Qty"/></Column>
            </columns>

            <items>
                <ColumnListItem id="_IDGenColumnListItem1">
                    <cells>
                        <Text id="_IDGenText24" text="{PurchaseOrder}"/>
                        <Text id="_IDGenText25" text="{PurchaseOrderItem}"/>
                        <Text id="_IDGenText26" text="{Material}"/>
                        <Text id="_IDGenText27" text="{OrderQuantity}"/>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

    </Page>
</mvc:View>
